{
  "name": "react-snake-game",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "react-snake-game",
      "version": "1.0.0",
      "type": "module",
      "description": "A modern Snake game built with React and TypeScript",
      "keywords": ["snake", "game", "react", "typescript", "vite", "arcade"],
      "author": "Your Name <your.email@example.com>",
      "license": "MIT",
      "homepage": "https://github.com/your-username/react-snake-game#readme",
      "repository": {
        "type": "git",
        "url": "https://github.com/your-username/react-snake-game.git"
      },
      "bugs": {
        "url": "https://github.com/your-username/react-snake-game/issues"
      },
      "scripts": {
        "dev": "vite",
        "build": "vite build",
        "build:preview": "vite build --mode preview",
        "build:analyze": "vite build --mode analyze",
        "preview": "vite preview",
        "preview:prod": "vite preview --port 4173 --host",
        "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
        "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
        "type-check": "tsc --noEmit",
        "type-check:watch": "tsc --noEmit --watch",
        "test": "vitest",
        "test:ui": "vitest --ui",
        "test:run": "vitest run",
        "test:coverage": "vitest run --coverage",
        "test:watch": "vitest watch",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "pre-commit": "lint-staged",
        "prepare": "husky",
        "serve": "serve dist -s -l 3000",
        "deploy": "npm run build && npm run serve",
        "clean": "rimraf dist node_modules/.vite",
        "clean:all": "rimraf dist node_modules package-lock.json",
        "reinstall": "npm run clean:all && npm install"
      },
      "dependencies": {
        "react": "^19.1.0",
        "react-dom": "^19.1.0",
        "react-router-dom": "^6.28.0",
        "lucide-react": "^0.468.0",
        "clsx": "^2.1.0",
        "nanoid": "^5.1.0",
        "framer-motion": "^11.17.0",
        "zustand": "^5.0.2",
        "use-sound": "^4.0.1",
        "confetti-react": "^2.3.0"
      },
      "devDependencies": {
        "@eslint/js": "^9.25.0",
        "@types/react": "^19.1.2",
        "@types/react-dom": "^19.1.2",
        "@types/node": "^22.10.5",
        "@vitejs/plugin-react": "^4.4.1",
        "eslint": "^9.25.0",
        "eslint-plugin-react-hooks": "^5.2.0",
        "eslint-plugin-react-refresh": "^0.4.19",
        "eslint-plugin-jsx-a11y": "^6.10.2",
        "eslint-plugin-import": "^2.31.0",
        "globals": "^16.0.0",
        "vite": "^6.3.5",
        "vite-plugin-pwa": "^0.21.1",
        "vite-plugin-svgr": "^4.2.0",
        "rollup-plugin-visualizer": "^5.14.0",
        "vite-plugin-checker": "^0.7.5",
        "typescript": "^5.7.3",
        "@vitest/ui": "^3.0.4",
        "vitest": "^3.0.4",
        "@vitest/coverage-v8": "^3.0.4",
        "jsdom": "^26.0.0",
        "@testing-library/react": "^16.0.1",
        "@testing-library/jest-dom": "^6.6.2",
        "@testing-library/user-event": "^14.5.2",
        "prettier": "^3.4.2",
        "prettier-plugin-organize-imports": "^4.1.0",
        "lint-staged": "^15.4.3",
        "husky": "^9.1.7",
        "serve": "^14.2.3",
        "rimraf": "^6.0.1"
      },
      "engines": {
        "node": ">=18.0.0",
        "npm": ">=9.0.0"
      },
      "browserslist": {
        "production": [
          ">0.2%",
          "not dead",
          "not op_mini all"
        ],
        "development": [
          "last 1 chrome version",
          "last 1 firefox version",
          "last 1 safari version"
        ]
      },
      "lint-staged": {
        "**/*.{js,jsx,ts,tsx,json,css,md}": [
          "prettier --write",
          "eslint --fix"
        ]
      }
    }
  },
