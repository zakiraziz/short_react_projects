{
  "name": "snake",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "A modern Snake game built with React featuring PWA, offline support, and advanced game mechanics",
  "keywords": ["snake", "game", "react", "vite", "pwa", "typescript", "arcade"],
  "author": "Your Name <your.email@example.com>",
  "license": "MIT",
  "homepage": "https://github.com/your-username/snake#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/snake.git"
  },
  "bugs": {
    "url": "https://github.com/your-username/snake/issues"
  },
  "scripts": {
    "dev": "vite",
    "dev:host": "vite --host",
    "dev:port": "vite --port 3001",
    "build": "vite build",
    "build:preview": "vite build --mode preview",
    "build:analyze": "vite build --mode analyze && npm run analyze:bundle",
    "build:staging": "vite build --mode staging",
    "build:production": "vite build --mode production",
    "preview": "vite preview",
    "preview:prod": "vite preview --port 4173 --host",
    "preview:staging": "vite preview --port 4174 --host --mode staging",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "lint:watch": "eslint . --ext .js,.jsx,.ts,.tsx --watch",
    "lint:report": "eslint . --ext .js,.jsx,.ts,.tsx --format html > eslint-report.html",
    "type-check": "tsc --noEmit",
    "type-check:watch": "tsc --noEmit --watch",
    "type-check:strict": "tsc --noEmit --strict",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest watch",
    "test:debug": "vitest --inspect-brk",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "format:watch": "onchange '**/*.{js,jsx,ts,tsx,json,css,md}' -- prettier --write {{changed}}",
    "pre-commit": "lint-staged",
    "prepare": "husky",
    "serve": "serve dist -s -l 3000",
    "serve:https": "serve -s --ssl-cert cert.pem --ssl-key key.pem dist -l 3000",
    "deploy": "npm run build && npm run serve",
    "deploy:preview": "npm run build:preview && npm run serve",
    "clean": "rimraf dist node_modules/.vite .vitest .nyc_output coverage",
    "clean:all": "rimraf dist node_modules package-lock.json yarn.lock pnpm-lock.yaml .vitest coverage",
    "reinstall": "npm run clean:all && npm install",
    "analyze:bundle": "npx vite-bundle-analyzer dist/stats.html",
    "security:audit": "npm audit",
    "security:fix": "npm audit fix",
    "security:ci": "npm ci --audit",
    "deps:check": "npx npm-check-updates",
    "deps:update": "npx npm-check-updates -u",
    "deps:install": "npm install",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "storybook:preview": "storybook preview",
    "benchmark": "node scripts/benchmark.js",
    "generate:icons": "node scripts/generate-icons.js",
    "generate:sitemap": "node scripts/generate-sitemap.js",
    "healthcheck": "node scripts/healthcheck.js",
    "postinstall": "npm run type-check",
    "prebuild": "npm run lint && npm run type-check && npm run test:run"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^6.28.0",
    "lucide-react": "^0.468.0",
    "clsx": "^2.1.1",
    "nanoid": "^5.1.0",
    "framer-motion": "^11.17.0",
    "zustand": "^5.0.2",
    "immer": "^10.1.1",
    "use-sound": "^4.0.1",
    "react-helmet-async": "^2.0.6",
    "react-spring": "^9.7.3",
    "react-use-gesture": "^10.3.0",
    "use-debounce": "^10.0.5",
    "react-hotkeys-hook": "^4.7.3",
    "localforage": "^1.10.0",
    "idb-keyval": "^6.2.1",
    "web-vitals": "^4.2.4",
    "canvas-confetti": "^1.9.3",
    "date-fns": "^4.1.0",
    "lodash-es": "^4.17.21",
    "rxjs": "^7.8.1",
    "js-cookie": "^3.0.5",
    "uuid": "^11.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@types/node": "^22.10.5",
    "@types/lodash-es": "^4.17.12",
    "@types/uuid": "^10.0.0",
    "@types/js-cookie": "^3.0.6",
    "@types/web-vitals": "^3.5.0",
    "@vitejs/plugin-react": "^4.4.1",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-security": "^3.0.1",
    "eslint-plugin-vitest": "^0.5.4",
    "eslint-plugin-testing-library": "^7.1.1",
    "globals": "^16.0.0",
    "vite": "^6.3.5",
    "vite-plugin-pwa": "^0.21.1",
    "vite-plugin-svgr": "^4.2.0",
    "rollup-plugin-visualizer": "^5.14.0",
    "vite-plugin-checker": "^0.7.5",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-html": "^3.2.2",
    "@vitejs/plugin-legacy": "^6.0.2",
    "vite-bundle-analyzer": "^1.3.0",
    "typescript": "^5.7.3",
    "@vitest/ui": "^3.0.4",
    "vitest": "^3.0.4",
    "@vitest/coverage-v8": "^3.0.4",
    "jsdom": "^26.0.0",
    "@testing-library/react": "^16.0.1",
    "@testing-library/jest-dom": "^6.6.2",
    "@testing-library/user-event": "^14.5.2",
    "@testing-library/dom": "^10.4.0",
    "prettier": "^3.4.2",
    "prettier-plugin-organize-imports": "^4.1.0",
    "prettier-plugin-packagejson": "^2.5.4",
    "lint-staged": "^15.4.3",
    "husky": "^9.1.7",
    "serve": "^14.2.3",
    "rimraf": "^6.0.1",
    "npm-check-updates": "^17.1.14",
    "onchange": "^7.1.0",
    "@storybook/react": "^8.4.6",
    "@storybook/react-vite": "^8.4.6",
    "@storybook/addon-essentials": "^8.4.6",
    "@storybook/addon-interactions": "^8.4.6",
    "@storybook/addon-links": "^8.4.6",
    "@storybook/test": "^8.4.6",
    "@storybook/jest": "^0.6.0",
    "@storybook/blocks": "^8.4.6",
    "@playwright/test": "^1.49.0",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all",
      "not ie > 0",
      "not samsung < 10",
      "not and_uc < 15"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version",
      "last 1 edge version"
    ]
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx}": [
      "eslint --fix --max-warnings=0",
      "prettier --write"
    ],
    "**/*.{json,css,md,yml,yaml}": [
      "prettier --write"
    ],
    "**/*.{scss,less}": [
      "prettier --write",
      "stylelint --fix"
    ],
    "**/package.json": [
      "prettier --write"
    ]
  },
  "packageManager": "npm@9.0.0",
  "volta": {
    "node": "18.20.4",
    "npm": "9.8.1"
  },
  "config": {
    "port": 3000,
    "previewPort": 4173,
    "storybookPort": 6006,
    "e2ePort": 3001
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "**/*.css",
    "**/*.scss",
    "**/*.sass"
  ],
  "module": "./dist/index.js",
  "main": "./dist/index.umd.cjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.umd.cjs",
      "types": "./dist/index.d.ts"
    },
    "./style.css": "./dist/style.css"
  }
}
